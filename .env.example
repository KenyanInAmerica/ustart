# -----------------------------------------------
# Environment identifier
# Values: local | staging | production
# Never set to "production" in .env.local
# -----------------------------------------------
NEXT_PUBLIC_ENVIRONMENT=local

# -----------------------------------------------
# Supabase — point at whichever project you are working against
# Local dev: use staging Supabase credentials
# Never put production credentials in .env.local
# -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------
# Site URL
# Local: http://localhost:3000
# Staging: https://your-staging-vercel-url.vercel.app
# Production: https://yourdomain.com
# -----------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------
# Stripe — payments and subscriptions (Feature 12, deferred)
# -----------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# -----------------------------------------------
# Resend — transactional email (Feature 13, deferred)
# -----------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_NOTIFICATION_EMAIL=your-admin-email@example.com

# -----------------------------------------------
# PostHog — analytics
# -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
